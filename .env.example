# Local SQLite database (created by `npx prisma migrate dev`).
DATABASE_URL="file:./dev.db"

# Anthropic API key — enables the daily AI insight + watchlist digest (optional).
# Everything else (prices, history, fundamentals) works without it.
# Get one at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# FRED API key — enables the macro strip (rates, yield curve, CPI). Optional.
# Free key: https://fredaccount.stlouisfed.org/apikeys
# FRED_API_KEY=

# Finnhub API key — enables analyst consensus (recommendation trend). Optional.
# Free key: https://finnhub.io/register
# FINNHUB_API_KEY=
